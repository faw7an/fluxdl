{
	"name": "electrobun-react-tailwind-vite",
	"version": "1.0.8",
	"description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
	"scripts": {
		"start": "vite build && GDK_SCALE=1 GDK_DPI_SCALE=1.25 electrobun dev",
		"dev:vite": "vite build",
		"dev": "GDK_SCALE=1 GDK_DPI_SCALE=1.25 electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:linux": "vite build && electrobun build --target=linux",
		"build:mac": "vite build && electrobun build --target=mac",
		"build:all": "vite build && electrobun build"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-progress": "^1.1.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tooltip": "^1.2.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.16.0",
		"file-type": "^22.0.1",
		"lucide-react": "^1.8.0",
		"p-queue": "^9.1.2",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}